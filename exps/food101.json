{
    "prefix": "",
    "dataset": "food101_lt",
    "memory_size": 0,
    "memory_per_class": 0,
    "fixed_memory": false,
    "shuffle": true,
    "init_cls": 10,
    "increment": 10,
    "model_name": "dime",
    "backbone_type": "vit_base_patch16_224_in21k_dime",
    "device": ["0"],
    "seed": [3],
    "print_forget": true,

    "use_imbalance_setting": true,
    "task_imb_factor": 0.01,
    "nb_tasks": 10,
    "imbalance_order": "shuffle",
    
    "rb_r_head_frac": 0.6,
    "rb_rho_head": 0.2,
    "rb_rho_tail": 0.9,

    "init_epochs": 20,
    "init_lr": 0.07,
    "later_epochs": 20,
    "later_lr": 0.07,
    "batch_size": 16,
    "weight_decay": 0.0005,
    "min_lr": 0,
    "optimizer": "sgd",
    "scheduler": "cosine",
    "pretrained": true,
    "vpt_type": "Deep",
    "prompt_token_num": 5,
    "ffn_num": 64,
    "use_diagonal": true,

    
    "moni_adam": false,
    "adapter_num": -1
}